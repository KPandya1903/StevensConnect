# ============================================================
# StevensConnect — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ---- Server ------------------------------------------------
NODE_ENV=development
PORT=4000

# ---- Database (dev) ----------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Note: Uses port 5434 to avoid conflict with any existing local PostgreSQL on 5432
DATABASE_URL=postgresql://stevensconnect:stevensconnect_dev@localhost:5434/stevensconnect

# ---- Database (test) ---------------------------------------
# Used by Jest integration tests. Separate DB — never the dev DB.
TEST_DATABASE_URL=postgresql://stevensconnect:stevensconnect_dev@localhost:5433/stevensconnect_test

# ---- Auth / JWT --------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_byte_hex_secret
JWT_EXPIRES_IN=15m

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRES_DAYS=30

# ---- CORS --------------------------------------------------
# The URL of the React client. In prod, set to your deployed domain.
CLIENT_ORIGIN=http://localhost:3000

# ---- Email (SMTP) ------------------------------------------
# For dev, use Mailtrap (https://mailtrap.io) or any SMTP sandbox.
# For prod, use Resend or SendGrid.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
EMAIL_FROM=noreply@stevensconnect.com

# ---- File Uploads ------------------------------------------
# UPLOAD_STORAGE: 'local' (dev) or 's3' (prod)
UPLOAD_STORAGE=local

# Max file sizes in bytes
UPLOAD_MAX_IMAGE_SIZE_BYTES=8388608
UPLOAD_MAX_AVATAR_SIZE_BYTES=5242880

# Only required when UPLOAD_STORAGE=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=stevensconnect-assets

# ---- Rate Limiting -----------------------------------------
# Max requests per window (per IP)
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=900000
