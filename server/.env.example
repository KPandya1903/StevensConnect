# ============================================================
# StevensConnect — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ---- Server ------------------------------------------------
NODE_ENV=development
PORT=4000

# ---- Database (dev) ----------------------------------------
DATABASE_URL=postgresql://stevensconnect:stevensconnect_dev@localhost:5434/stevensconnect

# ---- Database (test) ---------------------------------------
TEST_DATABASE_URL=postgresql://stevensconnect:stevensconnect_dev@localhost:5433/stevensconnect_test

# ---- Auth / JWT --------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<min-32-char-random-string>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# ---- CORS --------------------------------------------------
CLIENT_ORIGIN=http://localhost:3000

# ---- Email (SMTP) ------------------------------------------
# Dev: use Mailtrap (https://mailtrap.io) or any SMTP sandbox.
# Prod: use Resend or SendGrid.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
EMAIL_FROM=noreply@stevensconnect.com

# ---- File Uploads ------------------------------------------
# 'local' in dev, 's3' in prod
UPLOAD_STORAGE=local
UPLOAD_MAX_IMAGE_SIZE_BYTES=8388608
UPLOAD_MAX_AVATAR_SIZE_BYTES=5242880

# ---- AWS S3 (required when UPLOAD_STORAGE=s3) --------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=stevensconnect-assets

# ---- Rate Limiting -----------------------------------------
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=900000

# ---- Sentry (optional — leave blank in dev) ----------------
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY
